{
  "name": "canvex-test",
  "version": "1.0.0",
  "main": "main.js",
  "private": true,
  "scripts": {
    "detect-deps": "node scripts/install-missing-deps.js",
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "clean": "rimraf dist",
    "build": "vite build",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.canvex.app",
    "productName": "canvex-test",
    "win": {
      "target": "portable"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ]
  }
}
